# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Chat ID for the private founders console (bot must be a member).
FOUNDERS_CHAT_ID=

# --- Solana data ---
HELIUS_API_KEY=
# Shared secret used to verify Helius webhook payloads.
HELIUS_WEBHOOK_SECRET=

# --- Market data ---
BIRDEYE_API_KEY=
DEXSCREENER_BASE_URL=https://api.dexscreener.com
DEXSCREENER_TIMEOUT_SECONDS=10
SOLANA_CHAIN_ID=solana

# --- Storage ---
# Supabase: Project Settings → Database → Connection string → URI (not the publishable API key).
# Use the database password you set when creating the project. Example (Session pooler):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# Direct (port 5432): postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=
# Redis connection string, e.g. redis://default:pass@host:6379
REDIS_URL=

# --- LLM (for lore summaries) ---
ANTHROPIC_API_KEY=

# --- Observability (optional) ---
SENTRY_DSN=

# --- Lore (optional, defer until Phase 5) ---
TWITTER_BEARER=

# --- Runtime ---
# dev | prod. Controls polling vs webhook, log verbosity, etc.
ENV=dev
# Public URL of the bot webhook in prod (e.g. https://bot.example.com)
WEBHOOK_URL=
